# ── API Keys ──────────────────────────────────────────────────────────────────
# NewsAPI — get a free key at https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Anthropic — get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# SendGrid — get a key at https://app.sendgrid.com/settings/api_keys
# The sending domain / address must be verified in your SendGrid account
SENDGRID_API_KEY=your_sendgrid_key_here

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_FROM=digest@yourdomain.com
EMAIL_TO=you@example.com

# ── Digest config ─────────────────────────────────────────────────────────────
# The topic to search for (anything NewsAPI supports, e.g. "climate change",
# "bitcoin", "Formula 1", "quantum computing")
NEWS_TOPIC=artificial intelligence

# How many curated articles to include in each email
NUM_ARTICLES=5
